#!/usr/bin/env python3
#!/home/huangweilun/ENV/miniconda3/bin/python
import os
import pandas as pd
import numpy as np
import argparse
from importlib import import_module

from utils.wrappers import timeit
from processor import DataLoader
pd.set_option('display.max_columns', None)


def create_parser():
    import argparse
    parser = argparse.ArgumentParser(description="Run LEP analysis") 
    parser.add_argument("--config-yaml", "-c", help = "YAML file for configuration")
    parser.add_argument("--log-level", "-l", type = str, default = "INFO" )
    parser.add_argument("--output-dir", "-o", type = str, default = "output" )
    return parser


if __name__ == "__main__":
    parser = create_parser()
    args = parser.parse_args()

    import logging
    loglevel = logging.getLevelName(args.log_level.upper())
    logging.basicConfig(level = loglevel, format = ">>> [%(levelname)s] %(module).s%(name)s: %(message)s")
    log = logging.getLogger("LepAna")

    # analysis_config = Manager.Manager.read_yaml(args.config_yaml)
    # analysis_config["log_level"] = args.log_level
    # analysis_config["output_dir"] = args.output_dir
    analysis_config = {}
    analysis_config['DataLoader'] = {
        "tree_name": "t",
        "region_of_interest": "hadhad",

        "input_files": [
            "/eos/home-c/cmo/project/ZtautauLep/simulation/run/251108_Ztautau_pipm/simana_job_*_ttree_pipi.root",
            # "/eos/home-c/cmo/project/ZtautauLep/simulation/run/251108_Ztautau_pipm/simana_job_17903058_6_ttree_pipi.root",
        ],
        "output_dir": "251108_Ztautau_pipm",
    }

    analysis_config["PlotProcessor"] = {
        "output_dir": analysis_config["DataLoader"]["output_dir"],
    }
    analysis_config["TemporaryProcessor"] = {
        "output_dir": analysis_config["DataLoader"]["output_dir"],
    }

    os.makedirs(analysis_config["DataLoader"]["output_dir"], exist_ok = True)

    data_loader = DataLoader.DataLoader(analysis_config["DataLoader"])
    processors = {}
    for processor_name, processor_config in analysis_config.items():
        if processor_name == "DataLoader":
            continue
        processor_class = getattr(import_module(f"processor.{processor_name}"), processor_name)
        processors[processor_name] = processor_class(processor_config)
        processors[processor_name].run(data_loader)

    for processor in processors.values():
        processor.finalize()

    log.info("Done")
    os._exit(0)