#!/usr/bin/env python3
#!/home/huangweilun/ENV/miniconda3/bin/python
import os
import pandas as pd
import numpy as np
import argparse
import yaml
import copy
from importlib import import_module
import awkward as ak
import vector

from utils.wrappers import timeit
from processor import DataLoader
pd.set_option('display.max_columns', None)
vector.register_awkward()


def create_parser():
    import argparse
    parser = argparse.ArgumentParser(description="Run LEP analysis") 
    parser.add_argument("--config-yaml", "-c", help = "YAML file for configuration", default=os.environ.get("TREE_ANA_DIR") + "/config/config.yaml")
    parser.add_argument("--log-level", "-l", type = str, default = "INFO" )
    parser.add_argument("--output-dir", "-o", type = str, default = None )
    return parser


def read_yaml(yaml_file):
    with open(yaml_file, "r") as _info:
        yaml_info = yaml.safe_load(_info)  # probably a list of yaml dictionaries
    return yaml_info


if __name__ == "__main__":
    parser = create_parser()
    args = parser.parse_args()

    import logging
    loglevel = logging.getLevelName(args.log_level.upper())
    logging.basicConfig(level = loglevel, format = ">>> [%(levelname)s] %(module).s%(name)s: %(message)s")
    log = logging.getLogger("LepAna")

    analysis_config = read_yaml(args.config_yaml)
    global_configs = analysis_config.get("GlobalConfigs", {})

    output_dir = args.output_dir if args.output_dir is not None else global_configs.get('default_output_dir', './output/')

    os.makedirs(output_dir, exist_ok = True)


    global_configs = analysis_config.get("GlobalConfigs", {})

    data_loaders = {}
    for key, dl_config in analysis_config["DataLoaders"].items():
        dl_config_with_globals = copy.deepcopy(global_configs)
        dl_config_with_globals.update(dl_config)
        dl = DataLoader.DataLoader(dl_config_with_globals, output_dir=f"{output_dir}/{key}/")
        dl.postprocess()
        data_loaders[key] = dl

    data_loaders = {
        'data94': data_loaders['data94'],
        'Zqq': data_loaders['Zqq'],
        'Zll': data_loaders['Zll'],
        'Ztautau': data_loaders['Ztautau'],
    }

    # split signal categories from Ztautau data loader if specified
    if global_configs.get("signal_categories", None) is not None:
        log.info("Splitting signal categories from Ztautau data loader")
        log.info(f"Signal categories: {global_configs['signal_categories']}")
        ztautau_dl = data_loaders.pop('Ztautau')
        signal_categories = global_configs["signal_categories"]
        split_ztautau_dls = {}
        for cat_name, cat_list in signal_categories.items():
            log.info(f"Splitting category: {cat_name} from Ztautau data loader with categories: {cat_list}")
            if type(cat_list) is int or type(cat_list) is str:
                cat_list = [int(cat_list)]
            dl_cat = copy.deepcopy(ztautau_dl)
            for region, events in ztautau_dl.data.items():
                mask_cat = ak.zeros_like(events['event_category'], dtype=bool)
                for cat in cat_list:
                    mask_cat = mask_cat | (events['event_category'] == cat)
                cat_events = events[mask_cat]
                other_events = events[~mask_cat]

                dl_cat.data[region] = cat_events
                ztautau_dl.data[region] = other_events
            split_ztautau_dls[cat_name] = dl_cat
        split_ztautau_dls['Ztautau_others'] = ztautau_dl

        data_loaders = {**data_loaders, **split_ztautau_dls}


    for processor_name, processor_config in analysis_config['Processors'].items():
        processor_config_with_globals = copy.deepcopy(global_configs)
        processor_config_with_globals.update(processor_config)
        processor_class = getattr(import_module(f"processor.{processor_name}"), processor_name)
        processor = processor_class(processor_config_with_globals, output_dir=output_dir)
        processor.run(data_loaders)
        processor.finalize()

    log.info("Done")
    os._exit(0)